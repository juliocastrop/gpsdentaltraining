---
/**
 * Admin Create Event - GPS Dental Training
 * Create a new event
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import EventCreate from '../../../components/admin/EventCreate';
import { supabaseAdmin } from '../../../lib/supabase/client';

// Get user from Supabase Auth
const userId = Astro.locals.userId;
let isAdmin = false;
let userName = 'Admin';
let userEmail = 'admin@gpsdentaltraining.com';

if (userId) {
  const { data: userData } = await supabaseAdmin
    .from('users')
    .select('role, first_name, last_name, email')
    .eq('auth_id', userId)
    .single();

  isAdmin = userData?.role === 'admin' || userData?.role === 'staff';
  if (userData?.first_name) {
    userName = (userData.first_name + ' ' + (userData.last_name || '')).trim();
  }
  if (userData?.email) {
    userEmail = userData.email;
  }
} else if (import.meta.env.DEV) {
  isAdmin = true;
}
if (!userId || !isAdmin) {
  return Astro.redirect('/sign-in?redirect_url=/admin/events/new');
}

const currentPath = Astro.url.pathname;
---

<AdminLayout title="Create Event">
  <EventCreate
    client:load
    currentPath={currentPath}
    user={{ name: userName, email: userEmail }}
  />
</AdminLayout>
