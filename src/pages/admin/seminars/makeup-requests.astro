---
/**
 * Admin Seminar Makeup Requests - GPS Dental Training
 * Review and manage makeup session requests
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import SeminarMakeupRequests from '../../../components/admin/SeminarMakeupRequests.tsx';
import { supabaseAdmin } from '../../../lib/supabase/client';

// Get user from Supabase Auth
const userId = Astro.locals.userId;
let isAdmin = false;
let userName = 'Admin';
let userEmail = 'admin@gpsdentaltraining.com';

if (userId) {
  const { data: userData } = await supabaseAdmin
    .from('users')
    .select('role, first_name, last_name, email')
    .eq('auth_id', userId)
    .single();

  isAdmin = userData?.role === 'admin' || userData?.role === 'staff';
  if (userData?.first_name) {
    userName = (userData.first_name + ' ' + (userData.last_name || '')).trim();
  }
  if (userData?.email) {
    userEmail = userData.email;
  }
} else if (import.meta.env.DEV) {
  isAdmin = true;
}
if (!userId || !isAdmin) {
  return Astro.redirect('/sign-in?redirect_url=/admin/seminars/makeup-requests');
}

// Optional: filter by seminar if provided in query string
const seminarId = Astro.url.searchParams.get('seminar') || undefined;

const currentPath = Astro.url.pathname;
---

<AdminLayout title="Makeup Requests">
  <SeminarMakeupRequests
    client:load
    currentPath={currentPath}
    user={{ name: userName, email: userEmail }}
    seminarId={seminarId}
  />
</AdminLayout>
