---
/**
 * Admin Seminar Sessions - GPS Dental Training
 * View and manage seminar session schedules
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import SeminarSessions from '../../../components/admin/SeminarSessions.tsx';
import { supabaseAdmin } from '../../../lib/supabase/client';

// Get user from Supabase Auth
const userId = Astro.locals.userId;
let isAdmin = false;
let userName = 'Admin';
let userEmail = 'admin@gpsdentaltraining.com';

if (userId) {
  const { data: userData } = await supabaseAdmin
    .from('users')
    .select('role, first_name, last_name, email')
    .eq('auth_id', userId)
    .single();

  isAdmin = userData?.role === 'admin' || userData?.role === 'staff';
  if (userData?.first_name) {
    userName = (userData.first_name + ' ' + (userData.last_name || '')).trim();
  }
  if (userData?.email) {
    userEmail = userData.email;
  }
} else if (import.meta.env.DEV) {
  isAdmin = true;
}
if (!userId || !isAdmin) {
  return Astro.redirect('/sign-in?redirect_url=/admin/seminars/sessions');
}

// Get filter params
const seminarFilter = Astro.url.searchParams.get('seminar_id') || '';

// Fetch all seminars
const { data: seminars } = await supabaseAdmin
  .from('seminars')
  .select('id, title, year, total_sessions')
  .order('year', { ascending: false });

// Fetch sessions for selected seminar or all active seminars
let sessionsQuery = supabaseAdmin
  .from('seminar_sessions')
  .select(`
    *,
    seminar:seminar_id(id, title, year)
  `)
  .order('session_date', { ascending: true });

if (seminarFilter) {
  sessionsQuery = sessionsQuery.eq('seminar_id', seminarFilter);
} else {
  // Show only sessions from active seminars
  const activeSeminarIds = seminars?.filter(s => s.year >= new Date().getFullYear()).map(s => s.id) || [];
  if (activeSeminarIds.length > 0) {
    sessionsQuery = sessionsQuery.in('seminar_id', activeSeminarIds);
  }
}

const { data: sessions, error } = await sessionsQuery.limit(100);

if (error) {
  console.error('Error fetching sessions:', error);
}

const currentPath = Astro.url.pathname;
---

<AdminLayout title="Seminar Sessions">
  <SeminarSessions
    client:load
    currentPath={currentPath}
    user={{ name: userName, email: userEmail }}
    sessions={sessions || []}
    seminars={seminars || []}
    seminarFilter={seminarFilter}
  />
</AdminLayout>
