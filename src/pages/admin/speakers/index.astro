---
/**
 * Admin Speakers Management - GPS Dental Training
 * Create, edit, and manage speakers/instructors
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import SpeakersManagement from '../../../components/admin/SpeakersManagement';
import { supabaseAdmin } from '../../../lib/supabase/client';

// Get user from Supabase Auth
const userId = Astro.locals.userId;
let isAdmin = false;
let userName = 'Admin';
let userEmail = 'admin@gpsdentaltraining.com';

if (userId) {
  const { data: userData } = await supabaseAdmin
    .from('users')
    .select('role, first_name, last_name, email')
    .eq('auth_id', userId)
    .single();

  isAdmin = userData?.role === 'admin' || userData?.role === 'staff';
  if (userData?.first_name) {
    userName = (userData.first_name + ' ' + (userData.last_name || '')).trim();
  }
  if (userData?.email) {
    userEmail = userData.email;
  }
} else if (import.meta.env.DEV) {
  isAdmin = true;
}
if (!userId || !isAdmin) {
  return Astro.redirect('/sign-in?redirect_url=/admin/speakers');
}

// Fetch all speakers with event counts
const { data: speakers, error } = await supabaseAdmin
  .from('speakers')
  .select(`
    *,
    event_speakers(event_id)
  `)
  .order('name', { ascending: true });

if (error) {
  console.error('Error fetching speakers:', error);
}

// Transform to include event count
const speakersWithCounts = (speakers || []).map(s => ({
  ...s,
  event_count: s.event_speakers?.length || 0,
  event_speakers: undefined,
}));

// Fetch all events for assignment
const { data: events } = await supabaseAdmin
  .from('events')
  .select('id, title, slug')
  .order('start_date', { ascending: false });

const currentPath = Astro.url.pathname;
---

<AdminLayout title="Speakers">
  <SpeakersManagement
    client:load
    currentPath={currentPath}
    user={{ name: userName, email: userEmail }}
    speakers={speakersWithCounts}
    events={events || []}
  />
</AdminLayout>
