---
/**
 * HeroLayout - Layout for pages with full-bleed hero sections
 * Uses transparent navbar that changes on scroll
 */
import '../styles/global.css';
import Navbar from '../components/layout/Navbar';
import Footer from '../components/layout/Footer';
import { getSiteSettings, getFooterProps } from '../lib/data/site-settings-loader';

const siteSettings = await getSiteSettings();
const footerProps = getFooterProps(siteSettings);

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  logo?: string;
  logoWhite?: string;
}

const {
  title,
  description = 'GPS Dental Training - Professional dental education courses and CE credits',
  ogImage = '/og-default.jpg',
  noIndex = false,
  logo = siteSettings.logo_url,
  logoWhite = siteSettings.logo_white_url,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_APP_URL || 'https://gpsdentaltraining.com';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" href={siteSettings.favicon_url} />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

    <title>{title} | GPS Dental Training</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Transparent Navbar with scroll effect -->
    <slot name="header">
      <Navbar
        logo={logo}
        logoWhite={logoWhite}
        transparent={true}
        isLoggedIn={!!Astro.locals.userId}
        client:load
      />
    </slot>

    <!-- Main content - no top padding since hero goes under navbar -->
    <main class="flex-1">
      <slot />
    </main>

    <slot name="footer">
      <Footer {...footerProps} client:load />
    </slot>
  </body>
</html>
